/* 训练动作项样式 */
.exercise-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--color-border);
}

.exercise-row:last-child {
  border-bottom: none;
}

.exercise-row__icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-sm);
  background: var(--color-primary-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.exercise-row__icon image {
  width: 40rpx;
  height: 40rpx;
}

.exercise-row__info {
  flex: 1;
  min-width: 0;
}

.exercise-row__name {
  font-weight: 500;
  font-size: var(--font-body);
  display: block;
}

.exercise-row__detail {
  font-size: var(--font-meta);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
  display: block;
}

.exercise-row__check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.exercise-row__check--done {
  background: var(--color-success);
  border-color: var(--color-success);
}

.exercise-row__check--done text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}
