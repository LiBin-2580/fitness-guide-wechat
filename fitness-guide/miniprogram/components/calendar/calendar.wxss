/* 日历组件样式 */
.calendar {
  background: var(--color-surface);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.calendar__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.calendar__nav-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
  border: 2rpx solid var(--color-border);
}

.calendar__nav-btn text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
}

.calendar__nav-btn:active {
  background: var(--color-bg);
}

.calendar__title {
  font-size: var(--font-h3);
  font-weight: 600;
}

.calendar__week-header {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  margin-bottom: 12rpx;
}

.calendar__week-item {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  padding: 12rpx 0;
}

.calendar__grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.calendar__day {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  border-radius: 50%;
  position: relative;
}

.calendar__day:active {
  background: var(--color-primary-soft);
}

.calendar__day--empty {
  pointer-events: none;
}

.calendar__day--today {
  color: var(--color-primary);
  font-weight: 600;
}

.calendar__day--checked {
  background: var(--color-primary-soft);
  color: var(--color-primary);
  font-weight: 500;
}

.calendar__day--checked::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  background: var(--color-primary);
  border-radius: 50%;
}

.calendar__legend {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-top: 24rpx;
}

.calendar__legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.calendar__legend-item text {
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
}

.calendar__legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.calendar__legend-dot--checked {
  background: var(--color-primary);
}

.calendar__legend-dot--today {
  border: 2rpx solid var(--color-primary);
}
