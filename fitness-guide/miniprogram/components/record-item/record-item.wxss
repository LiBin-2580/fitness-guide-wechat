/* 训练记录项样式 */
.record-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--color-border);
}

.record-item:last-child {
  border-bottom: none;
}

.record-item__date {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-sm);
  background: var(--color-primary-soft);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.record-item__day {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.record-item__month {
  font-size: 18rpx;
  color: var(--color-primary);
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.record-item__info {
  flex: 1;
  min-width: 0;
}

.record-item__title {
  font-weight: 500;
  font-size: var(--font-body);
  display: block;
}

.record-item__desc {
  font-size: var(--font-meta);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
  display: block;
}

.record-item__duration {
  font-size: var(--font-meta);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}
