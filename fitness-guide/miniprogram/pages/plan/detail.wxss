/* 训练计划详情页样式 */
.plan-detail {
  padding: 0 32rpx 32rpx;
}

.plan-detail__info {
  margin-bottom: 24rpx;
}

.plan-detail__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.plan-detail__meta {
  display: flex;
  gap: 48rpx;
}

.plan-detail__meta-item {
  text-align: center;
}

.plan-detail__meta-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
  display: block;
}

.plan-detail__progress-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

/* 训练日切换 */
.plan-detail__day-tabs {
  display: flex;
  gap: 16rpx;
  white-space: nowrap;
}

.plan-detail__day-tab {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 32rpx;
  background: var(--color-surface);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}

.plan-detail__day-tab--active {
  background: var(--color-primary-soft);
  border-color: var(--color-primary);
  color: var(--color-primary);
}

.plan-detail__day-name {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.plan-detail__day-tab--active .plan-detail__day-name {
  color: var(--color-primary);
}

/* 操作按钮 */
.plan-detail__actions {
  margin-top: 48rpx;
}

.plan-detail__action-row {
  display: flex;
  gap: 24rpx;
  margin-top: 24rpx;
}
