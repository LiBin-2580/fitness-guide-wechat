/* 身体数据页样式 */
.body-page {
  padding: 0 32rpx 32rpx;
}

/* 类型切换 */
.body-page__tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.body-page__tab {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  background: var(--color-surface);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  font-size: var(--font-body);
  transition: all 0.2s ease;
}

.body-page__tab--active {
  background: var(--color-primary);
  border-color: var(--color-primary);
  color: #fff;
}

/* 当前数值 */
.body-page__current {
  text-align: center;
  margin-bottom: 32rpx;
  padding: 40rpx;
}

.body-page__current-value {
  font-size: 96rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.body-page__current-unit {
  font-size: var(--font-body);
  color: var(--color-text-secondary);
  margin-left: 8rpx;
}

/* 图表 */
.body-page__chart {
  margin-bottom: 32rpx;
}

.body-page__chart-area {
  background: var(--color-bg);
  border-radius: var(--radius-sm);
  min-height: 300rpx;
}

/* 历史记录 */
.body-page__add-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.body-page__add-btn text {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
}

.body-page__history-item {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--color-border);
}

.body-page__history-item:last-child {
  border-bottom: none;
}

.body-page__history-date {
  color: var(--color-text-secondary);
}

.body-page__history-value {
  font-weight: 500;
}

/* 弹窗 */
.body-page__modal {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 50;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s ease;
}

.body-page__modal--show {
  opacity: 1;
  pointer-events: auto;
}

.body-page__modal-sheet {
  width: 100%;
  background: var(--color-surface);
  border-top-left-radius: var(--radius-lg);
  border-top-right-radius: var(--radius-lg);
  padding: 48rpx 32rpx 80rpx;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.body-page__modal--show .body-page__modal-sheet {
  transform: translateY(0);
}

.body-page__modal-handle {
  width: 72rpx;
  height: 8rpx;
  background: var(--color-border);
  border-radius: 4rpx;
  margin: 0 auto 32rpx;
}

/* 表单 */
.body-page__form-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.body-page__form-group {
  flex: 1;
}

.body-page__form-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.body-page__form-input {
  width: 100%;
  padding: 24rpx 28rpx;
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  font-size: var(--font-body);
}

.body-page__form-input:focus {
  border-color: var(--color-primary);
}
