/* 个人中心页样式 */
.profile-page {
  padding: 0 32rpx 32rpx;
}

/* 用户信息 */
.profile-page__user {
  text-align: center;
  margin-bottom: 48rpx;
  padding-top: 16rpx;
}

.profile-page__avatar {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: var(--color-primary-soft);
  margin: 0 auto 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid var(--color-primary);
}

.profile-page__avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.profile-page__avatar-placeholder {
  font-size: 64rpx;
}

/* 统计行 */
.profile-page__stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rpx;
  background: var(--color-border);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 40rpx;
}

.profile-page__stat-item {
  background: var(--color-surface);
  padding: 28rpx 24rpx;
  text-align: center;
}

.profile-page__stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
  display: block;
}

.profile-page__stat-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
  display: block;
}

/* 成就徽章 */
.profile-page__badges {
  display: flex;
  gap: 32rpx;
  padding-bottom: 8rpx;
  white-space: nowrap;
}

.profile-page__badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.profile-page__badge--locked {
  opacity: 0.4;
}

.profile-page__badge-icon {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: var(--color-primary-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--color-primary);
}

.profile-page__badge--locked .profile-page__badge-icon {
  background: var(--color-bg);
  border-color: var(--color-border);
}

.profile-page__badge-icon image {
  width: 44rpx;
  height: 44rpx;
}

/* 设置列表 */
.profile-page__setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 2rpx solid var(--color-border);
}

.profile-page__setting-item:last-child {
  border-bottom: none;
}

.profile-page__setting-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.profile-page__setting-icon {
  font-size: 40rpx;
}

.profile-page__setting-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: var(--color-text-secondary);
  font-size: 26rpx;
}

.profile-page__setting-arrow {
  font-size: 32rpx;
}
