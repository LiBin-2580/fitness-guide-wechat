/* 首页样式 */
.index-page {
  padding: 0 32rpx 32rpx;
}

.index-page__greeting {
  padding-top: 8rpx;
  margin-bottom: 32rpx;
}

.index-page__greeting text {
  display: block;
}

/* 连续打卡卡片 */
.index-page__streak {
  background: linear-gradient(135deg, #1AAD19, #129312);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  color: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.index-page__streak-num {
  font-size: 72rpx;
  font-weight: 700;
  line-height: 1;
  display: block;
}

.index-page__streak-label {
  font-size: 26rpx;
  opacity: 0.85;
  margin-top: 8rpx;
  display: block;
}

/* 区域标题 */
.index-page__section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

/* 进度 */
.index-page__progress-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

/* 快捷入口 */
.index-page__quick-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.index-page__quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 28rpx 16rpx;
  background: var(--color-surface);
  border-radius: var(--radius-sm);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.index-page__quick-item:active {
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.index-page__quick-item image {
  width: 48rpx;
  height: 48rpx;
}

.index-page__quick-item text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}
