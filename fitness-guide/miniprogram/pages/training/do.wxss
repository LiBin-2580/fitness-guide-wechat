/* 训练打卡页样式 */
.training-page {
  min-height: 100vh;
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
}

/* 头部 */
.training-page__header {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  background: var(--color-surface);
  border-bottom: 2rpx solid var(--color-border);
}

.training-page__exit {
  color: var(--color-danger);
  font-size: var(--font-body);
}

.training-page__title {
  font-size: var(--font-h2);
  font-weight: 600;
}

.training-page__finish {
  color: var(--color-primary);
  font-size: var(--font-body);
}

/* 计时器 */
.training-page__timer {
  padding: 40rpx 32rpx;
  text-align: center;
}

.training-page__timer-display {
  font-size: 96rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  letter-spacing: -0.02em;
}

.training-page__timer-label {
  font-size: var(--font-meta);
  color: var(--color-text-secondary);
  display: block;
  margin-top: 8rpx;
}

/* 当前动作卡片 */
.training-page__action-card {
  background: var(--color-surface);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  margin: 0 32rpx 32rpx;
}

.training-page__action-hint {
  font-size: var(--font-meta);
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
  display: block;
}

.training-page__action-name {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.training-page__action-target {
  font-size: var(--font-meta);
  color: var(--color-text-secondary);
  display: block;
}

/* 组数指示器 */
.training-page__group-dots {
  display: flex;
  gap: 16rpx;
  justify-content: center;
  margin-top: 32rpx;
}

.training-page__group-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: var(--color-border);
  transition: background 0.2s ease;
}

.training-page__group-dot--done {
  background: var(--color-success);
}

.training-page__group-dot--current {
  background: var(--color-primary);
}

/* 步进器区域 */
.training-page__stepper-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

/* 完成按钮 */
.training-page__complete-btn {
  margin: 0 32rpx;
  padding: 28rpx;
  font-size: 32rpx;
}

/* 下一个动作 */
.training-page__next {
  margin: 0 32rpx;
  opacity: 0.7;
}

.training-page__next-hint {
  font-size: var(--font-meta);
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
  display: block;
}

/* 弹窗 */
.training-page__modal {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 50;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s ease;
}

.training-page__modal--show {
  opacity: 1;
  pointer-events: auto;
}

.training-page__modal-sheet {
  width: 100%;
  background: var(--color-surface);
  border-top-left-radius: var(--radius-lg);
  border-top-right-radius: var(--radius-lg);
  padding: 48rpx 32rpx 80rpx;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.training-page__modal--show .training-page__modal-sheet {
  transform: translateY(0);
}

.training-page__modal-handle {
  width: 72rpx;
  height: 8rpx;
  background: var(--color-border);
  border-radius: 4rpx;
  margin: 0 auto 32rpx;
}
