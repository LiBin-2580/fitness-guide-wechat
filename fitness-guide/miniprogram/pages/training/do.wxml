<!-- 训练打卡页 -->
<view class="training-page">
  <!-- 头部 -->
  <view class="training-page__header">
    <text class="training-page__exit" bindtap="exitTraining">退出训练</text>
    <text class="training-page__title">{{planName}}</text>
    <text class="training-page__finish" bindtap="finishTraining">完成</text>
  </view>

  <!-- 计时器 -->
  <view class="training-page__timer">
    <text class="training-page__timer-display">{{timerDisplay}}</text>
    <text class="training-page__timer-label">训练时长</text>
  </view>

  <!-- 当前动作卡片 -->
  <view class="training-page__action-card">
    <text class="training-page__action-hint">当前动作</text>
    <text class="training-page__action-name">{{currentAction.name}}</text>
    <text class="training-page__action-target">目标：{{currentAction.sets}} 组 × {{currentAction.reps}} 次</text>
    <view class="training-page__group-dots">
      <view
        wx:for="{{groupDots}}"
        wx:key="index"
        class="training-page__group-dot {{item.done ? 'training-page__group-dot--done' : ''}} {{item.current ? 'training-page__group-dot--current' : ''}}"
      />
    </view>
  </view>

  <!-- 重量调节 -->
  <view class="card" style="margin-bottom: 24rpx;">
    <view class="training-page__stepper-header">
      <text class="text-meta">重量</text>
      <text class="text-meta">目标 {{currentAction.weight}} {{currentAction.unit}}</text>
    </view>
    <view style="display: flex; justify-content: center;">
      <stepper
        value="{{weight}}"
        step="{{2.5}}"
        unit="kg"
        bind:change="handleWeightChange"
      />
    </view>
  </view>

  <!-- 次数调节 -->
  <view class="card" style="margin-bottom: 24rpx;">
    <view class="training-page__stepper-header">
      <text class="text-meta">次数</text>
      <text class="text-meta">目标 {{currentAction.reps}} 次</text>
    </view>
    <view style="display: flex; justify-content: center;">
      <stepper
        value="{{reps}}"
        min="{{1}}"
        unit="次"
        bind:change="handleRepsChange"
      />
    </view>
  </view>

  <!-- 完成本组按钮 -->
  <button class="btn btn-primary btn-full training-page__complete-btn" bindtap="completeSet">
    完成本组
  </button>

  <!-- 下一个动作 -->
  <view class="card training-page__next" style="margin-top: 32rpx;">
    <text class="training-page__next-hint">下一个动作</text>
    <text class="text-h3">{{nextAction.name}}</text>
    <text class="text-caption" style="margin-top: 4rpx;">
      <text wx:if="{{nextAction.sets > 0}}">{{nextAction.sets}} 组 × {{nextAction.reps}} 次 · 休息 {{nextAction.rest}}s</text>
      <text wx:else>所有动作已完成</text>
    </text>
  </view>

  <!-- 退出确认弹窗 -->
  <view
    class="training-page__modal {{showExitModal ? 'training-page__modal--show' : ''}}"
    bindtap="closeExitModal"
  >
    <view class="training-page__modal-sheet" catchtap="">
      <view class="training-page__modal-handle" />
      <text class="text-h2" style="margin-bottom: 16rpx; display: block;">确认退出？</text>
      <text class="text-caption" style="margin-bottom: 40rpx; display: block;">当前训练进度将不会保存</text>
      <view style="display: flex; gap: 24rpx;">
        <button class="btn btn-ghost btn-full" bindtap="confirmExit">退出</button>
        <button class="btn btn-primary btn-full" bindtap="closeExitModal">继续训练</button>
      </view>
    </view>
  </view>
</view>
