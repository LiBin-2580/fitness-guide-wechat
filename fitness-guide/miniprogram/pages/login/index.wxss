/* 登录页样式 */
.login-page {
  min-height: 100vh;
  background: var(--color-surface);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 64rpx;
}

.login-page__logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: var(--color-primary);
  margin-top: 120rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-page__logo image {
  width: 80rpx;
  height: 80rpx;
}

.login-page__title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.login-page__subtitle {
  font-size: var(--font-meta);
  color: var(--color-text-secondary);
  margin-bottom: 80rpx;
}

.login-page__form {
  width: 100%;
}

.login-page__form-group {
  margin-bottom: 32rpx;
}

.login-page__form-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.login-page__form-row .login-page__input {
  flex: 1;
}

.login-page__input {
  width: 100%;
  padding: 28rpx 32rpx;
  background: var(--color-bg);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: 30rpx;
}

.login-page__input:focus {
  border-color: var(--color-primary);
}

.login-page__code-btn {
  padding: 28rpx 32rpx;
  border: 2rpx solid var(--color-primary);
  border-radius: var(--radius-md);
  white-space: nowrap;
  flex-shrink: 0;
}

.login-page__code-btn text {
  font-size: var(--font-meta);
  color: var(--color-primary);
  font-weight: 500;
}

.login-page__code-btn--disabled {
  border-color: var(--color-border);
}

.login-page__code-btn--disabled text {
  color: var(--color-text-secondary);
}

.login-page__submit {
  margin-top: 16rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.login-page__divider {
  display: flex;
  align-items: center;
  gap: 32rpx;
  width: 100%;
  margin: 48rpx 0;
}

.login-page__divider-line {
  flex: 1;
  height: 2rpx;
  background: var(--color-border);
}

.login-page__divider-text {
  font-size: var(--font-meta);
  color: var(--color-text-secondary);
}

.login-page__wechat {
  display: flex;
  justify-content: center;
}

.login-page__wechat-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #07C160;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-page__wechat-btn:active {
  transform: scale(0.92);
}

.login-page__wechat-btn image {
  width: 48rpx;
  height: 48rpx;
}
