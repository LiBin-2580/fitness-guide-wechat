/* 样式变量定义 */
page {
  /* 色彩系统 */
  --color-primary: #1AAD19;
  --color-primary-soft: rgba(26, 173, 25, 0.12);
  --color-accent: #FF6B35;
  --color-accent-soft: rgba(255, 107, 53, 0.12);
  --color-success: #52C41A;
  --color-success-soft: rgba(82, 196, 26, 0.12);
  --color-warn: #FAAD14;
  --color-danger: #FF4D4F;
  --color-bg: #F5F5F5;
  --color-surface: #FFFFFF;
  --color-text: #333333;
  --color-text-secondary: #999999;
  --color-border: #E8E8E8;

  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 24rpx;
  --spacing-xl: 32rpx;

  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-full: 999rpx;

  /* 字号 */
  --font-h1: 36rpx;
  --font-h2: 32rpx;
  --font-h3: 30rpx;
  --font-body: 28rpx;
  --font-meta: 24rpx;
  --font-stat: 48rpx;
  --font-caption: 26rpx;
}
