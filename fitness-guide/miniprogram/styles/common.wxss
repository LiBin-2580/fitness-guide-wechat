/* 通用样式 */

/* 卡片 */
.card {
  background: var(--color-surface);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 按钮基础 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 40rpx;
  border-radius: var(--radius-sm);
  border: none;
  font-size: var(--font-body);
  font-weight: 500;
  line-height: 1;
}

.btn:active {
  opacity: 0.85;
  transform: scale(0.96);
}

.btn-primary {
  background: var(--color-primary);
  color: #fff;
}

.btn-accent {
  background: var(--color-accent);
  color: #fff;
}

.btn-ghost {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}

.btn-danger {
  background: transparent;
  color: var(--color-danger);
  border: 2rpx solid var(--color-danger);
}

.btn-sm {
  padding: 12rpx 24rpx;
  font-size: var(--font-meta);
}

.btn-full {
  width: 100%;
}

/* 标签 */
.pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 20rpx;
  background: var(--color-primary-soft);
  color: var(--color-primary);
  border-radius: var(--radius-full);
  font-size: var(--font-meta);
  font-weight: 500;
}

.pill-accent {
  background: var(--color-accent-soft);
  color: var(--color-accent);
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 20rpx;
  background: var(--color-bg);
  color: var(--color-text-secondary);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-full);
  font-size: var(--font-meta);
}

/* 进度条 */
.progress-track {
  height: 12rpx;
  background: var(--color-border);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

/* 文字 */
.text-h1 {
  font-size: var(--font-h1);
  font-weight: 600;
}

.text-h2 {
  font-size: var(--font-h2);
  font-weight: 600;
}

.text-h3 {
  font-size: var(--font-h3);
  font-weight: 600;
}

.text-body {
  font-size: var(--font-body);
}

.text-meta {
  font-size: var(--font-meta);
  color: var(--color-text-secondary);
}

.text-stat {
  font-size: var(--font-stat);
  font-weight: 700;
  line-height: 1.1;
}

.text-caption {
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 96rpx 48rpx;
  text-align: center;
}

.empty-state__icon {
  width: 128rpx;
  height: 128rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
}

.empty-state__title {
  font-size: var(--font-h2);
  font-weight: 500;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.empty-state__desc {
  font-size: var(--font-meta);
  color: var(--color-text-secondary);
  margin-bottom: 32rpx;
}

/* 加载骨架 */
.loading-skeleton {
  background: linear-gradient(90deg, var(--color-bg) 25%, var(--color-border) 50%, var(--color-bg) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radius-sm);
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 动画 */
@keyframes fade-in-up {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-in {
  opacity: 0;
  animation: fade-in-up 0.35s ease forwards;
}

.animate-in:nth-child(1) { animation-delay: 0.04s; }
.animate-in:nth-child(2) { animation-delay: 0.08s; }
.animate-in:nth-child(3) { animation-delay: 0.12s; }
.animate-in:nth-child(4) { animation-delay: 0.16s; }
.animate-in:nth-child(5) { animation-delay: 0.20s; }
.animate-in:nth-child(6) { animation-delay: 0.24s; }

/* 安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
